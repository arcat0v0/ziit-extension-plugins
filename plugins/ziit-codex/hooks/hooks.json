{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/track-activity.py\"",
            "timeout": 5,
            "statusMessage": "Recording Ziit activity"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/track-activity.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
